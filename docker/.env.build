# Dummy values for Docker image build only — not used at runtime.
NODE_ENV=development
TZ=UTC
PORT=3333
HOST=0.0.0.0
LOG_LEVEL=info
APP_KEY=build-time-placeholder-key-minimum-32-chars
# Build-only placeholder — entrypoint unsets localhost APP_URL at runtime so Coolify SERVICE_URL_APP wins.
APP_URL=http://localhost:3333
SESSION_DRIVER=cookie
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_DATABASE=build
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
