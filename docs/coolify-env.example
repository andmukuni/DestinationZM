# Paste into Coolify → Environment Variables (Production)
# Structured like LoanTrack — AdonisJS reads DB_USERNAME/APP_ENV aliases automatically.
#
# Coolify: set NODE_ENV, APP_ENV, APP_KEY, DB_*, REDIS_* as RUNTIME ONLY
# (uncheck "Available at Buildtime") so the Docker build can install devDependencies.

APP_NAME=DestinationZM
APP_ENV=production
APP_KEY=zKXHe-Ahdb7aPK1ylAJlRgTefktEaACi
APP_URL=http://vikwerqjk3n08u5bjy2uwqok.13.140.178.28.sslip.io

NODE_ENV=production
HOST=0.0.0.0
PORT=3333
TZ=UTC
LOG_LEVEL=info

RUN_MIGRATIONS=true

DB_CONNECTION=mysql
DB_HOST=13.140.178.27
DB_PORT=3310
DB_DATABASE=default
DB_USERNAME=mysql
DB_PASSWORD=REPLACE_WITH_DB_PASSWORD

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=false

REDIS_HOST=13.140.178.27
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=REPLACE_WITH_REDIS_PASSWORD

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=DestinationZM

SERVICE_URL_APP=http://vikwerqjk3n08u5bjy2uwqok.13.140.178.28.sslip.io
SERVICE_FQDN_APP=vikwerqjk3n08u5bjy2uwqok.13.140.178.28.sslip.io

# Optional SMTP fallbacks (prefer Settings → Email in the admin UI)
