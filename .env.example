# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=zKXHe-Ahdb7aPK1ylAJlRgTefktEaACi
APP_URL=http://${HOST}:${PORT}

# Session (use "file" in Docker/Coolify — requires /app/tmp volume)
SESSION_DRIVER=cookie

# Database (MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_DATABASE=DestinationZM

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=

# Docker / Coolify (optional — set in Coolify UI for production)
# HOST=0.0.0.0
# NODE_ENV=production
# SESSION_DRIVER=file
# RUN_MIGRATIONS=true
# See docs/coolify-deployment.md for full production checklist

# QuickBooks Online (optional fallback — prefer Settings UI for credentials)
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=http://localhost:3333/settings/quickbooks/callback
QUICKBOOKS_ENVIRONMENT=sandbox
QUICKBOOKS_SCOPES=com.intuit.quickbooks.accounting

# SMTP (optional fallback — prefer Settings → Email)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=
MAIL_FROM_NAME=

# SMS (optional fallback — prefer Settings → SMS)
SMS_PROVIDER=twilio
SMS_ACCOUNT_SID=
SMS_AUTH_TOKEN=
SMS_FROM_NUMBER=

# WhatsApp (optional fallback — prefer Settings → WhatsApp)
WHATSAPP_PROVIDER=meta
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_FROM_NUMBER=
